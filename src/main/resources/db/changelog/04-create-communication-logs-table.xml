<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- Create communication_logs table -->
    <changeSet id="create-communication-logs-table" author="dev">
        <createTable tableName="communication_logs">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="contact_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_comm_contact" references="contact(id)"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_comm_user" references="user(id)"/>
            </column>
            <column name="type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="notes" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="outcome" type="VARCHAR(500)"/>
            <column name="next_follow_up" type="TIMESTAMP"/>
            <column name="timestamp" type="TIMESTAMP" defaultValueDate="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified" type="TIMESTAMP" defaultValueDate="CURRENT_TIMESTAMP"/>
        </createTable>
        
        <!-- Create indexes for better query performance -->
        <createIndex tableName="communication_logs" indexName="idx_contact_id">
            <column name="contact_id"/>
        </createIndex>
        <createIndex tableName="communication_logs" indexName="idx_user_id">
            <column name="user_id"/>
        </createIndex>
        <createIndex tableName="communication_logs" indexName="idx_timestamp">
            <column name="timestamp"/>
        </createIndex>
        <createIndex tableName="communication_logs" indexName="idx_next_followup">
            <column name="next_follow_up"/>
        </createIndex>
        <createIndex tableName="communication_logs" indexName="idx_contact_timestamp">
            <column name="contact_id"/>
            <column name="timestamp"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
